pipeline {
    agent any

    environment {
        // Використовуємо одинарні лапки. Секрети будуть доступні через змінні оточення
        POSTGRES_SECRET = credentials('jenkins-postgres-credentials')
        
        DB_HOST = 'postgres' 
        DB_PORT = '5432'
        DB_NAME = 'mydatabase' 
        
        // PYTHONPATH з лапками для обробки пробілів
        PYTHONPATH = "${env.WORKSPACE}/PyTest DQ Framework"
        PARQUET_BASE_PATH = '/parquet_data' 
    }

    stages {
        stage('Prepare and Run Tests') {
            steps {
                dir('PyTest DQ Framework') {
                    // Використовуємо змінні через $ всередині одинарних лапок для безпеки
                    sh '''
                        # 1. Створення та активація venv
                        python3 -m venv venv
                        . venv/bin/activate
                        
                        # 2. Оновлення pip
                        pip install --upgrade pip
                        
                        # 3. Встановлення залежностей
                        if [ -f requirements.txt ]; then
                            pip install -r requirements.txt
                        else
                            pip install pytest pytest-html pandas>=2.2.3 pyarrow>=18.0.0 sqlalchemy psycopg2-binary python-dotenv
                        fi
                        
                        # 4. Створення папки для звіту
                        mkdir -p reports
                        
                        # 5. Запуск тестів (ВИПРАВЛЕНО: прибрано зайвий sh)
                        # Ми використовуємо змінні з credentials безпосередньо
                        DB_USER=$POSTGRES_SECRET_USR DB_PASS=$POSTGRES_SECRET_PSW \
                        python3 -m pytest . -m reconciliation --html=reports/dq_report.html --self-contained-html
                    '''
                }
            }
        }
    }

    post {
        always {
            dir('PyTest DQ Framework') {
                archiveArtifacts artifacts: 'reports/*.html', allowEmptyArchive: true
                echo "Звіт згенеровано. Перевір вкладку Artifacts у Jenkins."
            }
        }
    }
}