pipeline {
    agent any

    environment {
        // Отримуємо кренденціали (переконайся, що ID збігається в Jenkins)
        POSTGRES_SECRET = credentials('jenkins-postgres-credentials')
        
        // Налаштування для бази даних
        DB_HOST = 'postgres' 
        DB_PORT = '5432'
        DB_NAME = 'mydatabase' 
        DB_USER = "${env.POSTGRES_SECRET_USR}"
        DB_PASS = "${env.POSTGRES_SECRET_PSW}"
        
        // Шлях до проекту для Python
        PYTHONPATH = "${env.WORKSPACE}/PyTest DQ Framework"
    }

    stages {
        stage('Prepare and Run Tests') {
            steps {
                dir('PyTest DQ Framework') {
                    sh '''
                        # 1. Створення та активація віртуального середовища
                        python3 -m venv venv
                        . venv/bin/activate
                        
                        # 2. Оновлення інструментів
                        pip install --upgrade pip
                        
                        # 3. Примусове встановлення критичних бібліотек
                        # (Вирішує помилку 'No module named pytest')
                        pip install pytest pytest-html pandas pyarrow sqlalchemy psycopg2-binary
                        
                        # 4. Встановлення решти залежностей з файлу
                        if [ -f requirements.txt ]; then
                            pip install -r requirements.txt
                        fi
                        
                        # 5. Діагностика (побачимо в логах список встановленого)
                        pip list
                        
                        # 6. Підготовка папки звітів
                        mkdir -p reports
                        
                        # 7. Запуск тестів
                        python3 -m pytest tests -m "parquet_data or example" \
                        --db_host="${DB_HOST}" \
                        --db_port="${DB_PORT}" \
                        --db_name="${DB_NAME}" \
                        --db_user="${DB_USER}" \
                        --db_password="${DB_PASS}" \
                        --html=reports/dq_report.html \
                        --self-contained-html
                    '''
                }
            }
        }
    }

    post {
        always {
            dir('PyTest DQ Framework') {
                // Зберігаємо звіт як артефакт
                archiveArtifacts artifacts: 'reports/*.html', allowEmptyArchive: true
                echo "Тести завершені. Звіт збережено в Artifacts."
            }
        }
        failure {
            echo "❌ Білд впав. Перевір Console Output на наявність помилок інсталяції або зв'язку з БД."
        }
    }
}