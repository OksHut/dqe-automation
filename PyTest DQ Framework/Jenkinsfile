pipeline {
    agent any

    environment {
        // Отримуємо доступи з Jenkins Credentials
        POSTGRES_SECRET = credentials('jenkins-postgres-credentials')
        
        // Налаштування для внутрішньої мережі Jenkins
        DB_HOST = 'postgres' 
        DB_PORT = '5432'
        DB_NAME = 'mydatabase'
        DB_USER = "${env.POSTGRES_SECRET_USR}"
        DB_PASS = "${env.POSTGRES_SECRET_PSW}"
        
        // add path to project
        
        PYTHONPATH = "${env.WORKSPACE}/PyTest DQ Framework"
    }

    stages {
        stage('Prepare and Run Tests') {
            steps {
                // dir() гарантує, що всі команди виконуються всередині папки проекту
                dir('PyTest DQ Framework') {
                    sh '''
                        # 1. Створення та активація середовища
                        python3 -m venv venv
                        . venv/bin/activate
                        
                        # 2. Оновлення pip та інсталяція залежностей
                        pip install --upgrade pip
                        pip install -r requirements.txt
                        
                        # 3. Створення папки для звітів (щоб не було помилки запису)
                        mkdir -p reports
                        
                        # 4. Запуск тестів через модуль python -m pytest
                        # Це вирішує проблему "pytest: not found"
                        python3 -m pytest tests -m "parquet_data or example" \
                        --db_host="${DB_HOST}" \
                        --db_port="${DB_PORT}" \
                        --db_name="${DB_NAME}" \
                        --db_user="${DB_USER}" \
                        --db_password="${DB_PASS}" \
                        --html=reports/dq_report.html \
                        --self-contained-html
                    '''
                }
            }
        }
    }

    post {
        always {
            // Зберігаємо звіт як артефакт білда (можна скачати з меню Jenkins)
            dir('PyTest DQ Framework') {
                archiveArtifacts artifacts: 'reports/*.html', allowEmptyArchive: true
            }
        }
    }
}