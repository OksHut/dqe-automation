pipeline {
    agent any

    environment {
        POSTGRES_SECRET = credentials('jenkins-postgres-credentials')
        DB_HOST = 'postgres' 
        DB_NAME = 'mydatabase'
        DB_USER = "${env.POSTGRES_SECRET_USR}"
        DB_PASS = "${env.POSTGRES_SECRET_PSW}"
        PYTHONPATH = "${env.WORKSPACE}"
    }

    stages {
        stage('Checkout') {
            steps {
                // 1. Jenkins затягує твій репозиторій (разом з папкою src/data/ та тестами)
                checkout scm 
            }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                    python3 -m venv venv
                    . venv/bin/activate
                    pip install -r requirements.txt
                '''
            }
        }

        stage('Run Data Quality Tests') {
            steps {
                sh '''
                    . venv/bin/activate
                    # 2. Запускаємо тести, які ти розробила у VS Code
                    # Ми передаємо параметри бази через аргументи командного рядка
                    pytest tests/ -m "example or parquet_data" \
                    --db_host="${DB_HOST}" \
                    --db_port="5432" \
                    --db_name="${DB_NAME}" \
                    --db_user="${DB_USER}" \
                    --db_password="${DB_PASS}" \
                    --html=reports/dq_report.html \
                    --self-contained-html
                '''
            }
        }
    }

    post {
        always {
            // 3. Зберігаємо звіт, щоб ти могла його відкрити в Jenkins
            archiveArtifacts artifacts: 'reports/*.html'
            publishHTML([
                reportDir: 'reports',
                reportFiles: 'dq_report.html',
                reportName: 'Final DQ Report'
            ])
        }
    }
}